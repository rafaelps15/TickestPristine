{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ], // Exemplo de sink para log no console

    "MinimumLevel": "Information", // Nível mínimo de log (pode ser: Verbose, Debug, Information, Warning, Error, Fatal)

    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
      // Aqui você pode adicionar outros sinks, como File, Seq, etc.
    ],

    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ], // Informações adicionais nos logs

    "Properties": {
      "Application": "TICKEST"
    }
  },

  "JwSettings": {
    "SecretKey": "b7e2e53c7b04f7fc8eaf58ea79a2d9cfcffb2096c621e1d4d8e52977ec858d4fa",
    "Issuer": "localhost",
    "Audience": "localhost",
    "ExpirationInMinutes": 60
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=tickest_dev;Trusted_Connection=True;"
  },

  "AllowedHosts": "*"
}
